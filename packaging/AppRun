#!/bin/bash
set -e

HERE="$(dirname "$(readlink -f "${0}")")"
APPDIR="$HERE"

export LD_LIBRARY_PATH="$APPDIR/usr/lib:$APPDIR/usr/lib/x86_64-linux-gnu:$LD_LIBRARY_PATH"

PYTHON_DIR=$(ls -d "$APPDIR/usr/lib/python3."* 2>/dev/null | head -1)
if [ -n "$PYTHON_DIR" ]; then
    export PYTHONHOME="$APPDIR/usr"
    export PYTHONPATH="$APPDIR/usr/share/wengine:$PYTHON_DIR/site-packages:$PYTHONPATH"
fi

PYSIDE_QT=$(find "$APPDIR/usr/lib" -type d -name "Qt" 2>/dev/null | head -1)
if [ -n "$PYSIDE_QT" ]; then
    export QT_PLUGIN_PATH="$PYSIDE_QT/plugins:$QT_PLUGIN_PATH"
    export QT_QPA_PLATFORM_PLUGIN_PATH="$PYSIDE_QT/plugins/platforms:$QT_QPA_PLATFORM_PLUGIN_PATH"
    export QML2_IMPORT_PATH="$PYSIDE_QT/qml:$QML2_IMPORT_PATH"
fi

if [ "$XDG_SESSION_TYPE" = "wayland" ]; then
    export QT_QPA_PLATFORM="wayland;xcb"
else
    export QT_QPA_PLATFORM="xcb"
fi

export PATH="$APPDIR/usr/bin:$PATH"

exec "$APPDIR/usr/bin/wengine" "$@"